# LiveKit (required by backend and agent)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud

# OpenAI (required by backend and agent)
OPENAI_API_KEY=sk-...

# Deepgram (required by agent)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Google OAuth (required by backend)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Auth secrets (required by backend)
JWT_SECRET=change_me_in_production
SESSION_SECRET=change_me_in_production

# URLs (required by backend)
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ChromaDB — set automatically in docker-compose; override for external instance
CHROMA_URL=http://localhost:8001

# Optional: OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Set to 'true' to bypass Google OAuth for local testing
SKIP_AUTH=false
